    "@vercel/analytics": "^1.6.1",
    "clsx": "^1.2.1",
    "emoji-picker-react": "^4.18.0",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.562.0",
    "next": "^14.0.0",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "remark-breaks": "^4.0.0",
